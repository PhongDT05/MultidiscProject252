# Enable SQL-backed API integration
VITE_USE_BACKEND_API=false
VITE_API_BASE_URL=http://localhost:4000

# Enable live MQTT ingestion from ESP32 topics
VITE_ENABLE_MQTT=true

# MQTT broker over WebSocket (browser cannot use raw TCP MQTT)
# Example with Mosquitto WS listener: ws://localhost:9001
VITE_MQTT_BROKER_URL=ws://localhost:9001

# Optional MQTT auth
VITE_MQTT_CLIENT_ID=smartlab-web-client
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=

# Which lab receives MQTT updates
VITE_MQTT_LAB_ID=lab-01

# Ignore tiny numeric changes to reduce rerenders (absolute deltas)
VITE_MQTT_TEMP_EPSILON=0.1
VITE_MQTT_HUMIDITY_EPSILON=1
VITE_MQTT_LIGHT_EPSILON=5
VITE_MQTT_AIR_EPSILON=5

# Auto disabled when VITE_ENABLE_MQTT=true, but you can force disable explicitly
VITE_ENABLE_SIMULATOR=false
